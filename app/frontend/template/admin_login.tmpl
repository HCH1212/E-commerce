{{ define "admin_login" }}
<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ .Title }}</title>
    <link rel="stylesheet" href="/static/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
          crossorigin="anonymous" referrerpolicy="no-referrer"/>
    <style>
        body {
            min-height: 100vh;
            background: radial-gradient(circle at 20% 20%, #f2f8f5 0%, #eef3f8 45%, #e8eef6 100%);
        }
        .login-wrap { min-height: 100vh; }
        .login-card {
            width: 100%;
            max-width: 420px;
            border: 1px solid #e8ebf1;
            border-radius: 16px;
            box-shadow: 0 12px 28px rgba(16, 24, 40, 0.08);
            background: #fff;
        }
    </style>
</head>
<body>
<div class="container login-wrap d-flex align-items-center justify-content-center py-4">
    <div class="login-card p-4 p-md-5">
        <div class="text-center mb-4">
            <img src="https://jw.cqupt.edu.cn/images/logo.png" alt="logo" style="height:52px;" class="mb-2">
            <h3 class="mb-1">Admin Login</h3>
            <p class="text-muted mb-0">Sign in to manage products</p>
        </div>

        {{ if .Error }}
        <div class="alert alert-danger py-2" role="alert">
            Invalid username or password.
        </div>
        {{ end }}

        <form method="post" action="/admin/login">
            <div class="mb-3">
                <label class="form-label">Username</label>
                <input class="form-control" name="username" placeholder="admin" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input class="form-control" type="password" name="password" placeholder="admin" required />
            </div>
            <button class="btn btn-success w-100" type="submit">
                <i class="fa-solid fa-right-to-bracket me-1"></i>Login
            </button>
        </form>
    </div>
</div>
<script src="/static/js/bootstrap.bundle.min.js"></script>
</body>
</html>
{{ end }}