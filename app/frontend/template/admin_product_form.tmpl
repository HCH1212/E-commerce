{{ define "admin_product_form" }}
<!doctype html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ .Title }}</title>
    <link rel="stylesheet" href="/static/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
          crossorigin="anonymous" referrerpolicy="no-referrer"/>
    <style>
        :root {
            --admin-border: #e8ebf1;
            --admin-soft-bg: #f5f7fb;
        }
        body { background: linear-gradient(180deg, #f8f9fa 0%, #eef3f8 100%); }
        .admin-shell { min-height: calc(100vh - 56px); }
        .editor-card {
            border: 1px solid var(--admin-border);
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 8px 24px rgba(16, 24, 40, 0.06);
        }
        .editor-head {
            background: var(--admin-soft-bg);
            border-bottom: 1px solid var(--admin-border);
        }
        .thumb-preview {
            width: 100%;
            max-width: 260px;
            aspect-ratio: 1 / 1;
            object-fit: cover;
            border-radius: 12px;
            border: 1px solid #dee2e6;
            background: #fff;
        }
        .form-tip { font-size: .875rem; color: #6c757d; }
    </style>
</head>
<body>
<header>
    <nav class="navbar navbar-expand-lg bg-body-tertiary border-bottom">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" href="/">
                <img src="https://jw.cqupt.edu.cn/images/logo.png" alt="CQUPT Logo" style="height: 2.3em">
                <span class="fw-semibold">电商系统</span>
            </a>
            <div class="ms-auto d-flex align-items-center gap-2">
                <a class="btn btn-outline-success btn-sm" href="/admin/products">
                    <i class="fa-solid fa-table-list me-1"></i>商品列表
                </a>
                <form method="post" action="/admin/logout" class="d-inline">
                    <button class="btn btn-outline-secondary btn-sm" type="submit">退出登录</button>
                </form>
            </div>
        </div>
    </nav>
</header>

<main class="admin-shell py-4">
<div class="container" style="max-width: 980px;">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-1">{{ .Title }}</h2>
            <p class="text-muted mb-0">请保持商品信息准确完整，以提升店铺展示效果。</p>
        </div>
        <a class="btn btn-light border" href="/admin/products">返回列表</a>
    </div>

    <div class="editor-card bg-white">
        <div class="editor-head px-4 py-3">
            <span class="fw-semibold">商品详情</span>
        </div>
        <div class="card-body p-4">
            <form method="post" action="{{ .FormAction }}">
                <div class="row g-4">
                    <div class="col-lg-8">
                        <div class="mb-3">
                            <label class="form-label">商品名称</label>
                            <input class="form-control" name="name" value="{{ .Product.Name }}" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">商品描述</label>
                            <textarea class="form-control" name="description" rows="5" required>{{ .Product.Description }}</textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">图片 URL</label>
                            <input class="form-control" name="picture" value="{{ .Product.Picture }}" required />
                            <div class="form-tip mt-1">建议使用稳定的 HTTPS 图片地址，避免页面图片加载失败。</div>
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label">价格</label>
                                <input class="form-control" type="number" step="0.01" min="0" name="price" value="{{ .Product.Price }}" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label">分类（英文逗号分隔）</label>
                                <input class="form-control" name="categories" value="{{ .Categories }}" placeholder="例如：数码, 手机" />
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <label class="form-label">图片预览</label>
                        <div>
                            <img id="picturePreview" class="thumb-preview" src="{{ .Product.Picture }}" alt="商品预览图" />
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button class="btn btn-success" type="submit">
                        <i class="fa-solid fa-floppy-disk me-1"></i>{{ .SubmitLabel }}
                    </button>
                    <a class="btn btn-outline-secondary" href="/admin/products">取消</a>
                </div>
            </form>
        </div>
    </div>
</div>
</main>

<script src="/static/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
    var pictureInput = document.querySelector('input[name="picture"]');
    var preview = document.getElementById('picturePreview');
    if (!pictureInput || !preview) {
        return;
    }
    var fallback = 'https://via.placeholder.com/600x600?text=%E6%97%A0%E5%9B%BE%E7%89%87';
    var updatePreview = function () {
        var value = (pictureInput.value || '').trim();
        preview.src = value || fallback;
    };
    pictureInput.addEventListener('input', updatePreview);
    preview.addEventListener('error', function () {
        preview.src = fallback;
    });
    updatePreview();
})();
</script>
</body>
</html>
{{ end }}
